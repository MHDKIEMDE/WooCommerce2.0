# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="Monghetto"
APP_ENV=local                  # local | staging | production
APP_KEY=                       # php artisan key:generate
APP_DEBUG=true                 # false en production
APP_URL=http://localhost:8000
ROOT_DOMAIN=monghetto.com      # Domaine racine pour la détection des sous-domaines boutiques

LOG_CHANNEL=stack
LOG_LEVEL=debug                # debug | info | warning | error en production

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES (MySQL 8)
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Shop
DB_USERNAME=root
DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# CACHE & QUEUE (Redis recommandé en production)
# ─────────────────────────────────────────────────────────────────────────────
CACHE_STORE=redis              # array | redis | file
QUEUE_CONNECTION=redis         # sync (dev) | redis (prod)
SESSION_DRIVER=file            # file | redis | database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=0               # DB Redis réservée au cache
REDIS_QUEUE_DB=1               # DB Redis réservée aux queues

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP / Mailgun / SES)
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp               # smtp | ses | mailgun | sendmail | log (test)
MAIL_HOST=mailpit              # mailpit (dev) | smtp.mailgun.org (prod)
MAIL_PORT=1025                 # 1025 (mailpit) | 587 (smtp tls)
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null           # tls | ssl | null
MAIL_FROM_ADDRESS="noreply@agri-shop.fr"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# PAIEMENT — STRIPE
# Clés sur https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_...         # Clé publique (côté client)
STRIPE_SECRET=sk_test_...      # Clé secrète (côté serveur — JAMAIS côté client)
STRIPE_WEBHOOK_SECRET=whsec_.. # Signature webhook (dashboard Stripe → Webhooks)

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS PUSH — FIREBASE / FCM (HTTP v1)
# ─────────────────────────────────────────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# Télécharger le JSON depuis Firebase Console → Paramètres → Comptes de service

# ─────────────────────────────────────────────────────────────────────────────
# SANCTUM — API tokens Flutter
# ─────────────────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_TOKEN_EXPIRATION=43200  # Expiration des tokens en minutes (43200 = 30 jours). null = jamais.
# En prod : ajouter le domaine du SPA si nécessaire

# ─────────────────────────────────────────────────────────────────────────────
# STOCKAGE FICHIERS
# ─────────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public         # local | public | s3

# AWS S3 (optionnel — pour les images en production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=agri-shop-media
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────────────────────
# VITE (frontend)
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_STRIPE_KEY="${STRIPE_KEY}"

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP (CallMeBot — notifications de commandes)
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_PHONE=+2250000000000
WHATSAPP_CALLMEBOT_APIKEY=
